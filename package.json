{
	"name": "eslint-fix-utils",
	"version": "0.4.2",
	"description": "Utilities for ESLint rule fixers and suggestions. 🧑‍🔧",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/michaelfaith/eslint-fix-utils.git"
	},
	"license": "MIT",
	"contributors": [
		{
			"name": "JoshuaKGoldberg",
			"email": "npm@joshuakgoldberg.com",
			"url": "https://joshuakgoldberg.com"
		},
		{
			"name": "michael faith",
			"email": "michaelfaith@users.noreply.github.com",
			"url": "https://michael.faith"
		}
	],
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./lib/index.d.mts",
			"default": "./lib/index.mjs"
		}
	},
	"main": "lib/index.mjs",
	"module": "lib/index.mjs",
	"types": "lib/index.d.mts",
	"files": [
		"CHANGELOG.md",
		"lib/"
	],
	"scripts": {
		"build": "tsdown",
		"format": "prettier .",
		"lint": "eslint . --max-warnings 0",
		"lint:knip": "knip",
		"lint:spelling": "cspell \"**\" \".github/**/*\"",
		"prepare": "husky",
		"test": "vitest",
		"type-check": "tsc"
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write"
	},
	"devDependencies": {
		"@eslint-community/eslint-plugin-eslint-comments": "4.7.0",
		"@eslint/js": "10.0.1",
		"@eslint/markdown": "8.0.1",
		"@types/estree": "1.0.6",
		"@types/node": "24.12.0",
		"@vitest/coverage-v8": "4.1.2",
		"@vitest/eslint-plugin": "1.6.9",
		"console-fail-test": "0.6.1",
		"cspell": "10.0.0",
		"eslint": "10.2.0",
		"eslint-plugin-jsdoc": "62.9.0",
		"eslint-plugin-jsonc": "3.1.0",
		"eslint-plugin-n": "17.24.0",
		"eslint-plugin-package-json": "0.91.0",
		"eslint-plugin-perfectionist": "5.9.0",
		"eslint-plugin-regexp": "3.1.0",
		"eslint-plugin-yml": "3.3.0",
		"husky": "9.1.7",
		"knip": "6.9.0",
		"lint-staged": "16.4.0",
		"prettier": "3.8.0",
		"prettier-plugin-curly": "0.4.0",
		"prettier-plugin-packagejson": "3.0.0",
		"prettier-plugin-sh": "0.18.0",
		"tsdown": "0.21.10",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.0",
		"vitest": "4.1.2"
	},
	"peerDependencies": {
		"@types/estree": ">=1",
		"eslint": ">=8"
	},
	"peerDependenciesMeta": {
		"@types/estree": {
			"optional": true
		}
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": "^20.19.0 || ^22.12.0 || >=24.0.0"
	}
}
